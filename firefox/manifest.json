{
  "name": "abu",
  "version": "1.1.1",
  "description": "Abu",
  "manifest_version": 3,
  "permissions": ["storage"],
  "optional_permissions": ["userScripts"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "128": "icon.png"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "abu@scottosmckenzie.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
